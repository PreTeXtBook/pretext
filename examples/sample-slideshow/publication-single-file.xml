<!-- reveal.js testing publication file: a single-file slideshow.    -->
<!-- Embedded resources fold the reveal.js files, all stylesheets,   -->
<!-- and fonts into the one HTML file, and (implied, deliberately    -->
<!-- unstated here) the mathematics is embedded as SVG images, so    -->
<!-- the slideshow is network-detached in the browser                -->
<publication>

    <source>
        <directories external="external" generated="generated"/>
    </source>

    <revealjs>
        <appearance theme="solarized" custom-css="external/custom.css"/>
        <resources host="embedded"/>
        <controls display="yes" tutorial="yes" layout="bottom-right" backarrows="faded"/>
        <navigation mode="default"/>
    </revealjs>

</publication>
