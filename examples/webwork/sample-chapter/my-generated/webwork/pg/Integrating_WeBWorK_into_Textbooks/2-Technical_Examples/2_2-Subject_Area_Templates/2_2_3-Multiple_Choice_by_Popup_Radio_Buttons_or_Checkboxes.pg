DOCUMENT();

############################################################
# Load Macros
############################################################
loadMacros(
  "PGstandard.pl",
  "PGML.pl",
  "AnswerFormatHelp.pl",
  "parserCheckboxList.pl",
  "parserPopUp.pl",
  "parserRadioButtons.pl",
  "PGcourse.pl",
);
COMMENT('Authored in PreTeXt');

############################################################
# Header
############################################################
TEXT(beginproblem());

############################################################
# PG Setup Code
############################################################
Context('Numeric');
$color1 = PopUp(["?","Red","Blue","Green"], 2);
$color2 = RadioButtons(["Red","Blue","Green","None of these"], 1);
$color3 = CheckboxList(["Red","Blue","Green","None of these"], [1]);

############################################################
# Body
############################################################

BEGIN_PGML
My favorite color is [_]{$color1}{5}.

My favorite color is

[_]{$color2}{5}

My favorite color is

[_]{$color3}{5}

END_PGML

############################################################
# Solution
############################################################

BEGIN_PGML_SOLUTION
The correct answer is [$color1].

The correct answer is [$color2].

The correct answer is [$color3].

END_PGML_SOLUTION

############################################################
# End Problem
############################################################

ENDDOCUMENT();
