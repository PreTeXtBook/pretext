add_functions($gr[2], "x^2 for x in <-1,4> using color:blue and weight:2");
add_functions($gr[3], "x^3 for x in <-1,4> using color:blue and weight:2");
add_functions($gr[4], "e^x for x in <-1,4> using color:blue and weight:2");
add_functions($gr[5], "sin(x) for x in <-1,4> using color:blue and weight:2");
add_functions($gr[6], "cos(x) for x in <-1,4> using color:blue and weight:2");
add_functions($gr[7], "exp(-x^2) for x in <-1,4> using color:blue and weight:2");

