Context('Numeric');
$checks = CheckboxList(
    [
        [
            "${BM}e^{x^2} e^{1/x}${EM}",
            "${BM}e^{x^2} e^{x^{-1}}${EM}",
            "${BM}e^{ (x^3+1) / x}${EM}",
            "${BM}\dfrac{ e^{x^2} }{ e^x }${EM}",
            "${BM}e^{x^2} + e^{1/x}${EM}"
        ],
        "None of the above"
    ],
    [0, 1, 2],
    labels => "ABC",   # "abc", "123", "roman", "Roman"
);

############################################################
# Body
############################################################

BEGIN_PGML
Select all expressions that are equivalent to [`e^{x^2 + 1/x}\text{.}`] There may be more than one correct answer.

[_]{$checks}{5}

END_PGML

############################################################
