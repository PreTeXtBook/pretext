<!-- Publication file for the numbering stress-test document.            -->
<!-- Every level entry is set explicitly so that test scenarios can be   -->
<!-- exercised by editing one attribute at a time.                       -->
<!--                                                                     -->
<!-- Conventions of the level attribute:                                 -->
<!--   1  -  numbers carry chapter only                (e.g. 3.1)        -->
<!--   2  -  numbers carry chapter.section             (e.g. 3.1.1)      -->
<!--   3  -  numbers carry chapter.section.subsection  (e.g. 3.1.1.1)    -->
<!--                                                                     -->
<!-- divisions/@level is the maximum depth at which divisions themselves -->
<!-- carry numbers.  The other entries are each bounded above by it.     -->
<!--                                                                     -->
<!-- NOTE.  The "distinct" levels for figures and inline exercises are   -->
<!-- currently consumed from the source <docinfo>, not from this file.   -->
<!-- See <docinfo>/<numbering>/<figures>   and                           -->
<!--     <docinfo>/<numbering>/<exercises> in the .ptx source.           -->

<publication>

    <source>
        <directories external="ext" generated="gen"/>
    </source>

    <numbering>
        <!-- DO NOT EDIT divisions/@level during testing.                -->
        <!-- This document is the numbering stress test; numbering ALL  -->
        <!-- divisions is a precondition of the test.  The value below  -->
        <!-- is calibrated to the source and the part setting:          -->
        <!--                                                            -->
        <!--   part-structure   max depth in source       required      -->
        <!--                    (counted from the top)    @level        -->
        <!--   structural       part-chapter-section-                   -->
        <!--                    subsection-subsubsection      5         -->
        <!--   decorative       chapter-section-                        -->
        <!--                    subsection-subsubsection      4         -->
        <!--                                                            -->
        <!-- This file uses part-structure="structural" and the source  -->
        <!-- contains subsubsection.  Hence @level="5".                 -->
        <!--                                                            -->
        <!-- The OTHER level entries (blocks, projects, equations,      -->
        <!-- footnotes) are the knobs you edit between builds to test   -->
        <!-- different scenarios.                                       -->
        <divisions level="5" part-structure="structural"/>
        <blocks    level="2"/>
        <projects  level="2"/>
        <equations level="2"/>
        <footnotes level="2"/>
    </numbering>

    <html>
        <knowl exercise-inline="no"/>
    </html>

</publication>
